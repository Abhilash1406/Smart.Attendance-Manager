# Copy this to .env and source it before running the backend
# Or set these in your IDE run configuration

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart_attendance

# JWT — generate a secure 256-bit secret:
# openssl rand -base64 64
JWT_SECRET=your-minimum-256-bit-base64-secret-here
JWT_EXPIRATION_MS=86400000

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=162998811472-bduh3mgdctd89fo6dm39ntha4mbsmnj7.apps.googleusercontent.com

# Domain restriction
ALLOWED_EMAIL_DOMAIN=gmail.com

# Attendance window (24-hour HH:mm format)
ATTENDANCE_WINDOW_START=09:00
ATTENDANCE_WINDOW_END=09:15
PHOTO_RETENTION_DAYS=7

# File storage
UPLOAD_DIR=./uploads/attendance

# Allowed college network IPs (comma-separated, supports prefix matching)
ALLOWED_IPS=127.0.0.1,::1,192.168.1.,10.0.0.

# CORS — frontend URL
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=DEBUG
SERVER_PORT=8080
